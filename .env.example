# Supabase Credentials (EXAMPLE)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE=your-service-role-key

# Database Connection (Postgres)
