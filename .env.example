# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE=your-service-role-key

# ── Seguridad ─────────────────────────────────────────────────
# Pepper para pseudonimización de student_id (sha256 + pepper)
# Genera uno con: python -c "import secrets; print(secrets.token_hex(32))"
STUDENT_PEPPER=cambia-esto-por-una-cadena-aleatoria-larga

# ── Anthropic (LLM fallback en OMR) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Base de datos directa (opcional, para psql/migraciones) ──
# Reemplaza [PROJECT_ID] y [PASSWORD]
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
